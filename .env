# =============================================================================
# nopCommerce Playwright Automation — Active Environment Configuration
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
BASE_URL=https://demo.nopcommerce.com/
ENVIRONMENT=staging

# ---------------------------------------------------------------------------
# Browser Configuration
# ---------------------------------------------------------------------------
BROWSER=chromium
HEADLESS=true

# ---------------------------------------------------------------------------
# Test Execution
# ---------------------------------------------------------------------------
RETRY_COUNT=2
PARALLEL_WORKERS=4
TIMEOUT_MS=30000
NAVIGATION_TIMEOUT_MS=15000

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=info
LOG_TO_FILE=true

# ---------------------------------------------------------------------------
# Reporting
# ---------------------------------------------------------------------------
ALLURE_RESULTS_DIR=allure-results
REPORT_OUTPUT_DIR=reports
SCREENSHOT_DIR=screenshots
VIDEO_DIR=videos
SCREENSHOT_ON_FAILURE=true
VIDEO_ON_FAILURE=true
TRACE_ON_RETRY=true

# ---------------------------------------------------------------------------
# CI/CD
# ---------------------------------------------------------------------------
CI=false

# ---------------------------------------------------------------------------
# Test Data
# ---------------------------------------------------------------------------
DEFAULT_SEARCH_KEYWORD=Apple MacBook Pro
